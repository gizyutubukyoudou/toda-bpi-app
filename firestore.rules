rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isContractor()  { return isAuth() && role() == "contractor"; }
    function isSupervisor()  { return isAuth() && role() == "supervisor"; }
    function isManager()     { return isAuth() && role() == "manager"; }
    function isApprover()    { return isSupervisor() || isManager(); }

    // ── users ─────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if false; // Admin SDK only
    }

    // ── applications ──────────────────────────────────────
    match /applications/{appId} {
      // Contractor: read own submissions
      allow read: if isContractor()
        && resource.data.submittedBy == request.auth.uid;

      // Supervisor / Manager: read by workSiteName (set on user profile)
      allow read: if isApprover()
        && resource.data.workSiteName ==
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workSiteName;

      // Contractor: create draft
      allow create: if isContractor()
        && request.resource.data.status == "draft"
        && request.resource.data.submittedBy == request.auth.uid;

      // Contractor: update own draft (field edits only)
      allow update: if isContractor()
        && resource.data.submittedBy == request.auth.uid
        && resource.data.status == "draft"
        && request.resource.data.status == "draft";

      // All status transitions: Cloud Functions (Admin SDK) only
    }

    // ── notificationLogs ─────────────────────────────────
    match /notificationLogs/{logId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }
  }
}
